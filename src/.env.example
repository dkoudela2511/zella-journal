# PostgreSQL connection string.
# Lokálně např. přes Docker, nebo zdarma hostované: Neon (neon.tech) / Supabase.
DATABASE_URL="postgresql://user:password@localhost:5432/zella?schema=public"

# Tajný klíč pro NextAuth. Vygeneruj příkazem:  openssl rand -base64 32
NEXTAUTH_SECRET="zmen-me-na-nahodny-retezec"

# URL aplikace (lokálně nech http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"
